# .awesome-context handling
# Keep the folder and core memory files tracked.

# Ignore generated context artifacts
.awesome-context/ai-context.md
.awesome-context/minimal-context.md
.awesome-context/graph.json
.awesome-context/file-hashes.json

# Keep important memory files and skills tracked
!.awesome-context/memory.md
!.awesome-context/project-map.md
!.awesome-context/workflows.md
!.awesome-context/decisions.md
!.awesome-context/preferences.md
!.awesome-context/skills/
!.awesome-context/skills/**

# Dependencies and build output
node_modules/
dist/
build/
coverage/
*.tsbuildinfo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment files
.env
.env.*
!.env.example

# OS/editor noise
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.temp
.tmp*/
